@{
    ViewData["Title"] = "Truck Parts Inventory";
}

<div class="container mt-5">
    <div class="text-center mb-5">
        <h1 class="display-4">Sistema de inventario</h1>
        <p class="lead">Gestión de inventario de partes para camiones</p>
    </div>
    
    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-body text-center">
                    <h3 class="card-title"><i class="bi bi-box-seam"></i> Entradas y salidas</h3>
                    <p class="card-text">Registrar entradas y salidas de piezas</p>
                    <a href="/test" class="btn btn-info btn-lg">
                        <i class="fas fa-camera"></i> Entrada / Salida
                    </a>
                </div>
            </div>
        </div>
        
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-body text-center">
                    <h3 class="card-title">📊 Inventario</h3>
                    <p class="card-text">Revisar inventario de piezas</p>
                    <a href="/test/inventory-view" class="btn btn-outline-primary">
                        Ver Inventario
                    </a>
                </div>
            </div>
        </div>
        
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-body text-center">
                    <h3 class="card-title">📋 Transacciones</h3>
                    <p class="card-text">Revisar transacciones realizadas</p>
                    <a href="/test/transactions-view" class="btn btn-outline-secondary">
                        Ver Transacciones
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>